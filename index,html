<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Happy Birthday Moon ❤️</title>
  <meta name="description" content="A special birthday surprise for Moon — with countdown, cake, gallery, love messages, and more!"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
  <link rel="stylesheet" href="css/style.css"/>
</head>
<body>

  <!-- ========== PAGE 1: WELCOME ========== -->
  <section id="page-welcome" class="page active">
    <canvas id="welcome-canvas"></canvas>
    <div class="balloons-container" id="balloons"></div>
    <div class="welcome-content animate__animated animate__fadeInDown">
      <div class="sparkle-title">✨</div>
      <p class="subtitle">A Special Surprise For Someone Very Special</p>
      <div class="profile-circle-container">
        <div class="profile-circle-glow"></div>
        <img src="images/photo1.jpg" alt="Moon" class="profile-circle-img"/>
      </div>
      <h1 class="main-title">Happy Birthday<br/><span class="moon-name">Moon</span> ❤️</h1>
      <div class="heart-divider">💕 💖 💕</div>
      <button id="btn-start" class="btn-primary pulse-btn" onclick="goToPage('page-calendar')">
        <span>Start Countdown</span>
        <div class="btn-shine"></div>
      </button>
    </div>
  </section>

  <!-- ========== PAGE 2: CALENDAR COUNTDOWN ========== -->
  <section id="page-calendar" class="page">
    <canvas id="calendar-canvas"></canvas>
    <div class="calendar-container">
      <div class="calendar-stack" id="calendar-stack">
        <!-- Cards generated by JS -->
      </div>
      <div class="calendar-nav">
        <button id="btn-prev-day" class="btn-secondary" onclick="prevDay()" style="display:none">← Previous</button>
        <button id="btn-next-day" class="btn-primary" onclick="nextDay()">Next Day →</button>
      </div>
    </div>
  </section>

  <!-- ========== PAGE 3: BIRTHDAY REVEAL POPUP ========== -->
  <div id="page-reveal" class="reveal-overlay" style="display:none">
    <canvas id="fireworks-canvas"></canvas>
    <div class="reveal-popup animate__animated animate__zoomIn">
      <div class="popup-sparkles" id="popup-sparkles"></div>
      <div class="popup-emoji">🎉</div>
      <h2 class="popup-title">HAPPY BIRTHDAY</h2>
      <div class="popup-name">Dear MOON ❤️</div>
      <div class="profile-circle-container" style="width: 120px; height: 120px; margin: 15px auto;">
        <div class="profile-circle-glow"></div>
        <img src="images/photo1.jpg" alt="Moon" class="profile-circle-img"/>
      </div>
      <div class="popup-message">
        <p>You are one of the most beautiful parts of my life.</p>
        <p>May your smile always shine brighter than the stars.</p>
        <br/>
        <p>Wishing you endless happiness,<br/>love, success, and unforgettable memories.</p>
        <br/>
        <p class="popup-sign">Happy Birthday Moon ❤️</p>
      </div>
      <button class="btn-primary" id="btn-reveal-ok" onclick="goToCakePage()">
        OK ❤️
        <div class="btn-shine"></div>
      </button>
    </div>
  </div>

  <!-- ========== PAGE 4: BIRTHDAY CAKE ========== -->
  <section id="page-cake" class="page">
    <canvas id="cake-canvas"></canvas>
    <div class="cake-page-content">
      <h2 class="cake-heading animate__animated animate__fadeInDown">Make a Wish, Moon! 🎂</h2>
      <div class="cake-scene" id="cake-scene">
        <div class="cake-wrapper" id="cake-wrapper">
          <!-- Candles -->
          <div class="candles-row" id="candles-row">
            <div class="candle"><div class="flame"><div class="flame-inner"></div></div></div>
            <div class="candle"><div class="flame"><div class="flame-inner"></div></div></div>
            <div class="candle"><div class="flame"><div class="flame-inner"></div></div></div>
            <div class="candle"><div class="flame"><div class="flame-inner"></div></div></div>
            <div class="candle"><div class="flame"><div class="flame-inner"></div></div></div>
          </div>
          <!-- Cake Layers -->
          <div class="cake-top-layer">
            <div class="cake-top-deco">🌸 Happy Birthday 🌸</div>
          </div>
          <div class="cake-mid-layer">
            <div class="cake-mid-deco">❤️ Moon ❤️</div>
          </div>
          <div class="cake-bot-layer">
            <div class="cake-bot-deco">🍫 With Love 🍫</div>
          </div>
          <div class="cake-plate"></div>
        </div>
      </div>

      <!-- Music Player -->
      <div class="music-player" id="music-player">
        <div class="music-icon">🎵</div>
        <div class="music-info">
          <span class="music-title">Happy Birthday Song</span>
          <div class="music-wave" id="music-wave">
            <span></span><span></span><span></span><span></span><span></span>
          </div>
        </div>
        <div class="music-controls">
          <button id="btn-play" onclick="toggleMusic()" class="music-btn">▶ Play</button>
          <div class="volume-wrap">
            <span>🔊</span>
            <input type="range" id="volume-slider" min="0" max="1" step="0.05" value="0.5" oninput="setVolume(this.value)" class="volume-slider"/>
          </div>
        </div>
      </div>

      <button class="btn-primary cake-cut-btn" onclick="goToPage('page-cakecut')">
        Cut The Cake 🎂
        <div class="btn-shine"></div>
      </button>
    </div>
    <audio id="birthday-audio" loop>
      <source src="nim.mpeg" type="audio/mpeg"/>
      <source src="https://raw.githubusercontent.com/Yemnamehmood/Birthday-wish-with-music-player-/main/happy-birthday-155461.mp3" type="audio/mpeg"/>
    </audio>
  </section>

  <!-- ========== PAGE 5: CAKE CUTTING ========== -->
  <section id="page-cakecut" class="page">
    <canvas id="cakecut-canvas"></canvas>
    <div class="cakecut-content">
      <h2 class="cakecut-heading" id="cakecut-heading">Ready to cut? 🎂</h2>
      <div class="cakecut-scene" id="cakecut-scene">
        <div class="cakecut-cake-wrap" id="cakecut-cake-wrap">
          <div class="knife" id="knife">🔪</div>
          <div class="cakecut-cake" id="cakecut-cake">
            <div class="cut-left" id="cut-left">
              <div class="cake-half-inner">🎂</div>
            </div>
            <div class="cut-right" id="cut-right">
              <div class="cake-half-inner">🎂</div>
            </div>
          </div>
        </div>
        <button class="btn-primary cut-btn" id="btn-cut" onclick="cutTheCake()">
          Cut The Cake 🎂
          <div class="btn-shine"></div>
        </button>
      </div>
      <div class="bday-glow-text" id="bday-glow-text" style="display:none">
        🎉 Happy Birthday MOON ❤️ 🎉
      </div>
      <button class="btn-primary" id="btn-gallery" style="display:none" onclick="goToPage('page-gallery')">
        See Our Memories 📸
        <div class="btn-shine"></div>
      </button>
    </div>
  </section>

  <!-- ========== PAGE 6: MEMORY GALLERY ========== -->
  <section id="page-gallery" class="page">
    <canvas id="gallery-canvas"></canvas>
    <div class="gallery-content">
      <h2 class="gallery-heading animate__animated animate__fadeInDown">Our Beautiful Memories 📸</h2>
      <p class="gallery-sub">Every photo tells a story of love ❤️</p>
      <div class="gallery-carousel-container">
        <div class="carousel-3d" id="carousel-3d">
          <div class="carousel-item" style="--i: 0;" onclick="openLightbox('images/photo1.jpg')">
            <div class="carousel-item-inner">
              <img src="images/photo1.jpg" alt="Memory 1"/>
              <div class="carousel-overlay"><span>❤️ Memory 1</span></div>
            </div>
          </div>
          <div class="carousel-item" style="--i: 1;" onclick="openLightbox('images/photo2.jpg')">
            <div class="carousel-item-inner">
              <img src="images/photo2.jpg" alt="Memory 2"/>
              <div class="carousel-overlay"><span>💕 Memory 2</span></div>
            </div>
          </div>
          <div class="carousel-item" style="--i: 2;" onclick="openLightbox('images/photo3.jpg')">
            <div class="carousel-item-inner">
              <img src="images/photo3.jpg" alt="Memory 3"/>
              <div class="carousel-overlay"><span>🌸 Memory 3</span></div>
            </div>
          </div>
          <div class="carousel-item" style="--i: 3;" onclick="openLightbox('images/photo4.jpg')">
            <div class="carousel-item-inner">
              <img src="images/photo4.jpg" alt="Memory 4"/>
              <div class="carousel-overlay"><span>✨ Memory 4</span></div>
            </div>
          </div>
          <div class="carousel-item" style="--i: 4;" onclick="openLightbox('images/photo5.jpg')">
            <div class="carousel-item-inner">
              <img src="images/photo5.jpg" alt="Memory 5"/>
              <div class="carousel-overlay"><span>🎉 Memory 5</span></div>
            </div>
          </div>
          <div class="carousel-item" style="--i: 5;" onclick="openLightbox('images/photo6.jpg')">
            <div class="carousel-item-inner">
              <img src="WhatsApp Image 2026-06-01 at 1.12.29 PM.jpeg" alt="Memory 6"/>
              <div class="carousel-overlay"><span>💖 Memory 6</span></div>
            </div>
          </div>
        </div>
      </div>
      <button class="btn-primary gallery-next-btn" onclick="goToPage('page-message')">
        A Final Message 💌
        <div class="btn-shine"></div>
      </button>
    </div>
    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" onclick="closeLightbox()">
      <button class="lightbox-close" onclick="closeLightbox()">✕</button>
      <img id="lightbox-img" src="" alt="Memory"/>
    </div>
  </section>

  <!-- ========== PAGE 7: FINAL LOVE MESSAGE ========== -->
  <section id="page-message" class="page">
    <canvas id="message-canvas"></canvas>
    <div class="message-content">
      <div class="message-card glassmorphism">
        <div class="message-header">💌</div>
        <div class="typed-text" id="typed-text"></div>
        <div class="message-signature" id="message-signature" style="opacity:0">
          <div class="sig-line"></div>
          <p>With Love,<br/><em>Your Special Person</em> ❤️</p>
        </div>
      </div>
      <div class="floating-flowers" id="floating-flowers"></div>
    </div>
  </section>

  <!-- Global floating hearts layer -->
  <div class="global-hearts" id="global-hearts"></div>

  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
  <script src="js/script.js"></script>
</body>
</html>
